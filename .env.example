# Copy this to .env and fill in your values
# DO NOT commit .env to git — Azure uses Application Settings instead

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
OWNER_TELEGRAM_ID=your-telegram-user-id
KITCHEN_GROUP_ID=your-kitchen-group-id

# Webhook (for production / Azure)
WEBHOOK_URL=https://your-app.azurewebsites.net/webhook
WEBHOOK_SECRET=random-secret-string-here
